// Online C compiler to run C program online
#include <stdio.h>
#include <stdbool.h>

int factorial(int n){
    if(n == 1){
        return 1;
    }
    return n * factorial(n-1);
}

int main(){
    int num;
    scanf("%d", &num);
    printf("Factorial of %d is %d", num, factorial(num));
    return 0;
}
