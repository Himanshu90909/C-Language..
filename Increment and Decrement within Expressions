#include <stdio.h>

int main() {
    int baseScore = 100;  
    int bonus = 20;       
    int redeemed = 5; 
    
   // write your code here
   int total = baseScore + bonus;
   
   printf("Score after bonus addition: %d\n", total);      

    // Show final values of bonus and redeemed
    int final_values = total - redeemed;
    final_values++;
    printf("Score after redemption: %d\n", final_values);
    bonus++;
    printf("Final bonus value: %d\n", bonus);   
    redeemed--;
    printf("Final redeemed value: %d\n", redeemed);     

    return 0;
}
