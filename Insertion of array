#include <stdio.h>

int main() {
    int arr[10] = {1, 2, 3, 4, 5};
    int size = 5;
    int pos = 2;      // Insert at index 2
    int value = 99;

    // Shift elements to the right
    for(int i = size; i > pos; i--) {
        arr[i] = arr[i - 1];
    }

    // Insert value
    arr[pos] = value;
    size++;

    // Print array
    for(int i = 0; i < size; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
