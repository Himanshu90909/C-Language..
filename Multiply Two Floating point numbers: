# include <stdio.h>
// The floating point numbers are a way to represent real numbers with both whole parts and fractional parts.In this article , we will learn how to write a C program to find the product of two floatingg-point numbers.//

float multiply(float a, float b){
    return a * b;
}

int main(){
    float A = 2.12, B = 3.88, product;
    
    product = multiply(A, B);
    
    printf("Product of entered numbers is: %.3f", product);
    
    return 0;
}
