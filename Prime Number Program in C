#include <stdio.h>

int main() {
	// your code goes here
	int n;
	printf("Enter the prime number: ");
	scanf("%d", &n);
	int cnt = 0;
	
	if(n<=1)
	    printf("%d is not prime", n);
	else{
	    for (int i = 2; i * i <= n; i++){
	        if (n % i == 0)
	            cnt++;
	    }
	    
	    if (cnt > 0)
	        printf("%d is NOT PRIME", n);
	    else
	        printf("%d is prime", n);
	}
	return 0;
	
}
