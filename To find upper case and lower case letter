#include <stdio.h>

int main() {
    char ch;
    printf("Enter first letter of day: \n");
    scanf("%c", &ch); 
    
    if (ch >= 'A' && ch <= 'Z'){
        printf("Upper in case");
        
    }else if (ch >= 'a' && ch <= 'z') {
        printf("lower case \n");
    }else{
        printf("not english letter\n");
    }
    

    return 0;
}
