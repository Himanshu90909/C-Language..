#include <stdio.h>

int main() {
    int arr[2][5] = {
        {1, 2, 3, 4, 5},
        {3, 4, 5, 6, 7}
    };

    int i, j;

    printf("Intersection elements are:\n");

    for (i = 0; i < 5; i++) {
        for (j = 0; j < 5; j++) {
            if (arr[0][i] == arr[1][j]) {
                printf("%d ", arr[0][i]);
            }
        }
    }

    return 0;
}
